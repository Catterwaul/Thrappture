{"topicSections":[{"anchor":"Topics","identifiers":["doc:\/\/Thrappture\/documentation\/Thrappture\/Notes-on-Conversion","doc:\/\/Thrappture\/documentation\/Thrappture\/ThrowingPropertyWrapper"]},{"title":"Functions","generated":true,"identifiers":["doc:\/\/Thrappture\/documentation\/Thrappture\/zip(_:)"],"anchor":"Functions"},{"title":"Extended Modules","generated":true,"identifiers":["doc:\/\/Thrappture\/documentation\/Thrappture\/Swift"],"anchor":"Extended-Modules"}],"hierarchy":{"paths":[[]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Treat "},{"type":"codeVoice","code":"Optional"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Result"},{"type":"text","text":" like the throwing property wrappers they are."}],"metadata":{"externalID":"Thrappture","role":"collection","title":"Thrappture","symbolKind":"module","modules":[{"name":"Thrappture"}],"roleHeading":"Framework"},"variants":[{"paths":["\/documentation\/thrappture"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/Thrappture\/documentation\/Thrappture","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Property wrappers cannot throw."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Optional"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Result"},{"type":"text","text":" are not property wrappers."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"This package imagines what life would be like if those statements were not true. 🤩","type":"text"}]},{"type":"thematicBreak"},{"type":"heading","anchor":"Whats-a-Throwing-Property-Wrapper","level":4,"text":"What’s a “Throwing Property Wrapper”?"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some types are conceptually just wrappers around a value, giving it additional behavior. Swift uses "},{"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/properties\/#Property-Wrappers","isActive":true},{"type":"text","text":" to represent these types."}]},{"type":"paragraph","inlineContent":[{"text":"But while throwing errors from properties is supported, throwing errors from a property wrapper’s ","type":"text"},{"code":"wrappedValue","type":"codeVoice"},{"text":" property, specifically, is not (yet). That’s what a “throwing property wrapper” would employ.","type":"text"}]},{"type":"heading","anchor":"Optional-and-Result-should-be-throwing-property-wrappers","level":3,"text":"Optional and Result should be throwing property wrappers."},{"type":"paragraph","inlineContent":[{"code":"Optional","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Result","type":"codeVoice"},{"text":" both predate property wrappers, but it’s the right model for them, and we should embrace that as much as possible.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"While we can’t actually "},{"type":"emphasis","inlineContent":[{"text":"turn them","type":"text"}]},{"type":"text","text":" into throwing property wrappers, thinking of them that way enables aids with understanding the helpful utilities found in this package."}]},{"type":"heading","anchor":"Optional","level":4,"text":"Optional"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Optional"},{"type":"text","text":" acts "},{"type":"emphasis","inlineContent":[{"type":"text","text":"halfway"}]},{"type":"text","text":" to being a property wrapper."}]},{"type":"paragraph","inlineContent":[{"text":"You can ","type":"text"},{"inlineContent":[{"inlineContent":[{"text":"set","type":"text"}],"type":"strong"}],"type":"emphasis"},{"text":" an optional to what would be its “","type":"text"},{"code":"\"wrappedValue","type":"codeVoice"},{"text":"”.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["var value: Optional = 1","value = 2"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"But there is no mechanism in place to assign an optional to an instance of its wrapped value."}]},{"syntax":"swift","type":"codeListing","code":["let newValue: Int = value \/\/ Value of optional type 'Int?' must be unwrapped to a value of type 'Int'"]},{"type":"paragraph","inlineContent":[{"text":"And it’s as if ","type":"text"},{"type":"codeVoice","code":"Optional"},{"text":" somehow had an overloaded ","type":"text"},{"type":"codeVoice","code":"wrappedValue"},{"text":" ","type":"text"},{"type":"codeVoice","code":"set"},{"text":" accessor to match that, because you can also ","type":"text"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"set"}],"type":"strong"}],"type":"emphasis"},{"text":" an optional to be another optional.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["value = .some(3)","value = nil"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Property wrappers deal with that kind of conflation by using "},{"inlineContent":[{"text":"projected values","type":"text"}],"type":"emphasis"},{"type":"text","text":", by way of “"},{"code":"$","type":"codeVoice"},{"type":"text","text":"” syntax. If "},{"code":"Optional","type":"codeVoice"},{"type":"text","text":" were a throwing property wrapper, the syntax would be this, instead:"}]},{"syntax":"swift","type":"codeListing","code":["@Optional var value = 1","value = 2","$value = .some(3)","$value = nil","let newValue: Int = try value"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"What would that last line throw? "},{"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Optional.Nil"}],"identifier":"doc:\/\/Thrappture\/documentation\/Thrappture\/Swift\/Optional\/Nil","overridingTitle":"Optional.Nil","isActive":true},{"type":"text","text":"."}]},{"type":"heading","anchor":"Result","level":4,"text":"Result"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Result"},{"type":"text","text":" doesn’t have the conflation problem that "},{"type":"codeVoice","code":"Optional"},{"type":"text","text":" does, but that’s because it doesn’t offer any syntactic sugar."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"Result"},{"type":"text","text":" were a throwing property wrapper, the syntax for a “"},{"type":"codeVoice","code":"Result"},{"type":"text","text":" version” of the previous example would be this:"}]},{"syntax":"swift","type":"codeListing","code":["@Result<_, Int?.Nil> var value = 1","value = 2","$value = .success(3)","$value = .failure(nil)","let newValue: Int = try value"]},{"type":"thematicBreak"},{"type":"heading","anchor":"Usage-Examples","level":3,"text":"Usage Examples"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You’ve got the source code, so aside from reading this documentation, see the "},{"type":"strong","inlineContent":[{"type":"text","text":"Tests"}]},{"type":"text","text":" folder for example usage! 😺"}]}]}],"sections":[],"references":{"https://docs.swift.org/swift-book/documentation/the-swift-programming-language/properties/#Property-Wrappers":{"title":"property wrappers","titleInlineContent":[{"type":"text","text":"property wrappers"}],"identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/properties\/#Property-Wrappers","url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/properties\/#Property-Wrappers","type":"link"},"doc://Thrappture/documentation/Thrappture/Swift":{"url":"\/documentation\/thrappture\/swift","type":"topic","abstract":[],"title":"Swift","identifier":"doc:\/\/Thrappture\/documentation\/Thrappture\/Swift","role":"collection","kind":"symbol"},"doc://Thrappture/documentation/Thrappture/zip(_:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"zip","kind":"identifier"},{"text":"<each ","kind":"text"},{"text":"Sequence","kind":"genericParameter"},{"text":">(repeat each ","kind":"text"},{"text":"Sequence","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Sequence","preciseIdentifier":"s:ST","kind":"typeIdentifier"},{"text":"<(repeat (each ","kind":"text"},{"text":"Sequence","kind":"typeIdentifier"},{"text":").","kind":"text"},{"text":"Element","preciseIdentifier":"s:ST7ElementQa","kind":"typeIdentifier"},{"text":")>\n","kind":"text"}],"role":"symbol","identifier":"doc:\/\/Thrappture\/documentation\/Thrappture\/zip(_:)","title":"zip(_:)","type":"topic","kind":"symbol","url":"\/documentation\/thrappture\/zip(_:)","abstract":[]},"doc://Thrappture/documentation/Thrappture/Notes-on-Conversion":{"title":"Notes on Conversion","kind":"article","type":"topic","role":"article","abstract":[],"identifier":"doc:\/\/Thrappture\/documentation\/Thrappture\/Notes-on-Conversion","url":"\/documentation\/thrappture\/notes-on-conversion"},"doc://Thrappture/documentation/Thrappture/Swift/Optional/Nil":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Nil"}],"title":"Optional.Nil","role":"symbol","kind":"symbol","identifier":"doc:\/\/Thrappture\/documentation\/Thrappture\/Swift\/Optional\/Nil","abstract":[{"text":"An error that represents that an ","type":"text"},{"type":"codeVoice","code":"Optional"},{"text":" was ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}],"url":"\/documentation\/thrappture\/swift\/optional\/nil","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Nil"}]},"doc://Thrappture/documentation/Thrappture/ThrowingPropertyWrapper":{"kind":"symbol","identifier":"doc:\/\/Thrappture\/documentation\/Thrappture\/ThrowingPropertyWrapper","title":"ThrowingPropertyWrapper","fragments":[{"text":"protocol","kind":"keyword"},{"text"